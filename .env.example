MOTIONFORGE_ENVIRONMENT=development
MOTIONFORGE_SECRET_KEY=replace-with-at-least-32-random-bytes
MOTIONFORGE_DATABASE_URL=postgresql+psycopg://motionforge:motionforge@postgres:5432/motionforge
MOTIONFORGE_STORAGE_ROOT=/data/storage
MOTIONFORGE_MODEL_BACKEND=movenet
MOTIONFORGE_MODEL_PATH=/models/movenet-singlepose-lightning.onnx
MOTIONFORGE_SAMPLE_FPS=8
MOTIONFORGE_QUEUE_MODE=celery
MOTIONFORGE_CELERY_BROKER_URL=redis://redis:6379/0
MOTIONFORGE_CELERY_RESULT_BACKEND=redis://redis:6379/1
MOTIONFORGE_ALLOWED_ORIGINS=http://localhost:3000
MINIO_ROOT_USER=motionforge
MINIO_ROOT_PASSWORD=replace-this-password
NEXT_PUBLIC_API_URL=http://localhost:8000
